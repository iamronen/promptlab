<%= render "devise/shared/auth_frame" do %>
  <h2 class="mb-6 text-xl font-semibold text-gray-900 dark:text-white">Sign up</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="mb-4">
      <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
                        class:
                          "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:placeholder-gray-400 dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <% if @minimum_password_length %>
        <p class="mt-0.5 text-xs text-gray-500 dark:text-gray-400">(<%= @minimum_password_length %> characters minimum)</p>
      <% end %>
      <%= f.password_field :password, autocomplete: "new-password",
                           class:
                             "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password",
                           class:
                             "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
    </div>

    <div class="actions">
      <%= f.submit "Sign up",
                   class:
                     "prompt-btn-primary w-full cursor-pointer rounded-lg border-0 px-4 py-2.5 text-sm font-semibold" %>
    </div>
  <% end %>

  <div class="mt-6 text-sm text-gray-600 dark:text-gray-400">
    <%= render "devise/shared/links" %>
  </div>
<% end %>
