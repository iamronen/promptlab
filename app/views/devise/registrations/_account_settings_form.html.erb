<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-4">
    <%= f.label :display_name, "Display name", class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.text_field :display_name, autocomplete: "name",
                     class:
                       "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
  </div>

  <div class="mb-4">
    <span class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Avatar</span>
    <% if resource.avatar_previewable? %>
      <div class="mb-3 flex items-center gap-3">
        <%= image_tag url_for(resource.avatar.variant(:thumb)),
                      alt: "Current avatar",
                      class: "size-16 rounded-full object-cover ring-2 ring-gray-200 dark:ring-gray-600" %>
        <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
          <%= check_box_tag "user[remove_avatar]", "1", false, class: "size-4 rounded border-gray-300 text-prompt-accent focus:ring-prompt-accent" %>
          Remove avatar
        </label>
      </div>
    <% end %>
    <%= f.file_field :avatar, accept: "image/*",
                     class:
                       "mt-1 block w-full text-sm text-gray-700 file:mr-3 file:rounded-lg file:border-0 file:bg-prompt-accent file:px-3 file:py-2 file:text-sm file:font-medium file:text-white hover:file:opacity-90 dark:text-gray-300 dark:file:bg-blue-600" %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">PNG, JPEG, WebP, or GIF. Max 5 MB.</p>
  </div>

  <div class="mb-4">
    <%= f.label :email, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email",
                      class:
                        "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
  </div>

  <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
    <p class="mb-4 text-sm text-amber-800 dark:text-amber-200">Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
  <% end %>

  <div class="mb-4">
    <%= f.label :password, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <span class="text-xs text-gray-500 dark:text-gray-400">(leave blank if you don&apos;t want to change it)</span>
    <%= f.password_field :password, autocomplete: "new-password",
                         class:
                           "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
    <% if @minimum_password_length %>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= @minimum_password_length %> characters minimum</p>
    <% end %>
  </div>

  <div class="mb-4">
    <%= f.label :password_confirmation, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password",
                         class:
                           "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
  </div>

  <div class="mb-6">
    <%= f.label :current_password, class: "mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300" %>
    <span class="text-xs text-gray-500 dark:text-gray-400">(we need your current password to confirm your changes)</span>
    <%= f.password_field :current_password, autocomplete: "current-password",
                         class:
                           "mt-1 block w-full rounded-lg border border-gray-300 px-3 py-2 text-gray-900 shadow-sm focus:border-prompt-accent focus:outline-none focus:ring-1 focus:ring-prompt-accent dark:border-gray-600 dark:bg-gray-700 dark:text-white dark:focus:border-blue-400 dark:focus:ring-blue-400" %>
  </div>

  <div class="actions">
    <%= f.submit "Update",
                 class:
                   "prompt-btn-primary w-full cursor-pointer rounded-lg border-0 px-4 py-2.5 text-sm font-semibold" %>
  </div>
<% end %>

<h3 class="mt-10 border-t border-gray-200 pt-8 text-lg font-semibold text-gray-900 dark:border-gray-600 dark:text-white">Cancel my account</h3>

<p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
  Unhappy?
  <%= button_to "Cancel my account",
                registration_path(resource_name),
                data: { turbo_confirm: "Are you sure?" },
                method: :delete,
                class:
                  "prompt-btn-danger mt-2 inline-block no-underline" %>
</p>
