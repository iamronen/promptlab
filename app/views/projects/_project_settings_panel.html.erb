<% seqs = @project.sequences.to_a %>
<% threads_count = seqs.count(&:thread?) %>
<% sequences_count = seqs.count(&:sequence?) %>
<% return_to = local_assigns[:return_to] %>

<div class="project-settings-panel-body">
  <% if @project.errors.any? %>
    <section class="errors prompt-form-errors !mb-3 !mt-0" role="alert">
      <h2>Unable to save</h2>
      <ul>
        <% @project.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </section>
  <% end %>

  <div class="project-settings-modal-title-row">
    <div
      class="project-settings-modal-title-display flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1"
      data-project-settings-modal-target="titleDisplay"
    >
      <h2 id="project-settings-modal-heading" class="m-0 min-w-0 truncate text-xl font-extrabold tracking-tight text-prompt-heading">
        <%= @project.name %>
      </h2>
      <button
        type="button"
        class="prompt-btn-secondary shrink-0 px-2.5 py-1 text-[0.8rem]"
        data-action="click->project-settings-modal#beginEditName"
      >
        Edit
      </button>
    </div>

    <div hidden data-project-settings-modal-target="titleEdit">
      <%= form_with model: @project,
                    url: project_path(@project),
                    method: :patch,
                    class: "flex flex-wrap items-end gap-2",
                    data: { turbo_frame: "_top" } do |f| %>
        <%= hidden_field_tag :return_to, return_to if return_to.present? %>
        <%= f.label :name, "Project name", class: "visually-hidden" %>
        <%= f.text_field :name,
                         required: true,
                         autocomplete: "off",
                         aria: { labelledby: "project-settings-modal-heading" },
                         class:
                           "min-w-[12rem] flex-1 rounded-lg border border-prompt-field-border px-2 py-2 text-[0.9rem]",
                         data: { project_settings_modal_target: "nameInput" } %>
        <%= f.submit "Save", class: "prompt-btn-primary shrink-0 px-3 py-2 text-[0.85rem]" %>
        <button
          type="button"
          class="prompt-btn-secondary shrink-0 px-3 py-2 text-[0.85rem]"
          data-action="click->project-settings-modal#cancelEditName"
        >
          Cancel
        </button>
      <% end %>
    </div>
  </div>

  <p class="m-0 mt-3 text-sm/6 text-prompt-muted">
    <%= pluralize(threads_count, "thread") %>
    <span class="text-prompt-subtle" aria-hidden="true"> · </span>
    <%= pluralize(sequences_count, "sequence") %>
  </p>

  <p class="m-0 mt-2">
    <%= link_to "Download PDF",
                export_pdf_project_path(@project),
                class: "text-sm font-medium text-prompt-heading underline decoration-prompt-subtle underline-offset-2 hover:decoration-prompt-heading",
                data: { turbo: false } %>
  </p>

  <section
    class="project-settings-sharing-section mt-6 border-t border-gray-200 pt-5 dark:border-gray-700"
    data-controller="project-sharing"
    data-project-sharing-update-url-value="<%= project_path(@project) %>"
  >
    <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-prompt-muted">
      Sharing
    </h3>

    <div class="mt-4 flex items-center gap-3">
      <label class="project-sharing-switch">
        <input
          type="checkbox"
          role="switch"
          class="project-sharing-switch__input"
          <%= "checked" if @project.sharing_allowed %>
          aria-labelledby="project-sharing-toggle-label-<%= @project.id %>"
          data-project-sharing-target="toggle"
          data-action="change->project-sharing#onToggleChange"
        />
        <span class="project-sharing-switch__track" aria-hidden="true"></span>
        <span
          id="project-sharing-toggle-label-<%= @project.id %>"
          class="project-sharing-switch__label"
        >
          Enable sharing
        </span>
      </label>
    </div>

    <div
      class="mt-4"
      <%= "hidden" unless @project.sharing_allowed %>
      data-project-sharing-target="sharesList"
    >
      <h4 class="m-0 text-xs font-semibold uppercase tracking-wide text-prompt-muted">
        Shares
      </h4>
      <div id="project_shares_list_content" class="project-shares-list-content">
        <%= render "projects/project_shares_list", project: @project %>
      </div>
    </div>

    <%= render "sequences/thread_share_mount", project: @project %>
  </section>

  <section
    class="project-settings-taxonomies-section mt-6 border-t border-gray-200 pt-5 dark:border-gray-700"
    data-controller="project-taxonomies"
    data-project-taxonomies-index-url-value="<%= project_taxonomies_path(@project) %>"
    data-project-taxonomies-update-url-value="<%= project_path(@project) %>"
  >
    <div class="flex flex-wrap items-end justify-between gap-2">
      <h3 class="m-0 text-sm font-semibold uppercase tracking-wide text-prompt-muted">
        Taxonomies
      </h3>
      <button
        type="button"
        class="prompt-btn-secondary px-2.5 py-1 text-[0.8rem]"
        data-action="click->project-taxonomies#openAddTaxonomyPanel"
      >
        Add taxonomy
      </button>
    </div>

    <div class="project-default-process-taxonomy mt-4 space-y-2">
      <label
        class="block text-xs font-semibold uppercase tracking-wide text-prompt-muted"
        for="default-process-taxonomy-<%= @project.id %>"
      >
        Default process taxonomy
      </label>
      <select
        id="default-process-taxonomy-<%= @project.id %>"
        class="w-full max-w-md rounded-lg border border-prompt-field-border px-2 py-2 text-[0.9rem] text-prompt-heading disabled:cursor-not-allowed disabled:opacity-50"
        disabled
        data-project-taxonomies-target="defaultProcessTaxonomySelect"
        data-action="change->project-taxonomies#onDefaultProcessTaxonomyChange"
      >
      </select>
      <p
        class="m-0 text-sm text-prompt-muted"
        hidden
        data-project-taxonomies-target="defaultProcessTaxonomyHelp"
      >
        Enable process tracking on a single-select taxonomy to coordinate work in this project.
      </p>
    </div>
    <div
      hidden
      class="mt-3"
      data-project-taxonomies-target="addTaxonomyPanel"
    >
      <div class="flex flex-wrap items-end gap-2">
        <label class="visually-hidden" for="new-taxonomy-name-<%= @project.id %>">New taxonomy name</label>
        <input
          id="new-taxonomy-name-<%= @project.id %>"
          type="text"
          class="min-w-[12rem] flex-1 rounded-lg border border-prompt-field-border px-2 py-2 text-[0.9rem]"
          placeholder="Name"
          autocomplete="off"
          data-project-taxonomies-target="newTaxonomyName"
          data-action="keydown->project-taxonomies#onNewTaxonomyKeydown"
        />
        <button type="button" class="prompt-btn-primary px-3 py-2 text-[0.85rem]" data-action="click->project-taxonomies#createTaxonomy">
          Create
        </button>
        <button type="button" class="prompt-btn-secondary px-3 py-2 text-[0.85rem]" data-action="click->project-taxonomies#cancelAddTaxonomyPanel">
          Cancel
        </button>
      </div>
    </div>
    <div class="project-taxonomies-list mt-3" data-project-taxonomies-target="list" aria-live="polite"></div>

    <dialog
      class="project-delete-confirm-dialog rounded-xl border border-gray-200 bg-white p-5 shadow-xl dark:border-gray-600 dark:bg-gray-800"
      aria-labelledby="taxonomy-value-delete-heading-<%= @project.id %>"
      data-project-taxonomies-target="deleteTermDialog"
      data-action="click->project-taxonomies#onDeleteTermDialogBackdrop"
    >
      <h3 id="taxonomy-value-delete-heading-<%= @project.id %>" class="m-0 mb-2 text-base font-semibold text-prompt-heading">
        Delete this value?
      </h3>
      <p class="m-0 mb-4 text-sm text-prompt-heading" data-project-taxonomies-target="deleteTermDialogMessage"></p>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          class="prompt-btn-secondary border-red-200 bg-red-600 px-3 py-2 text-[0.85rem] text-white hover:bg-red-700 dark:border-red-900 dark:bg-red-700 dark:hover:bg-red-600"
          data-action="click->project-taxonomies#confirmDeleteTermDialog"
        >
          Delete
        </button>
        <button
          type="button"
          class="prompt-btn-secondary px-3 py-2 text-[0.85rem]"
          data-action="click->project-taxonomies#cancelDeleteTermDialog"
        >
          Cancel
        </button>
      </div>
    </dialog>

    <dialog
      class="bundle-edit-dialog bundle-edit-dialog--taxonomy-settings"
      aria-labelledby="taxonomy-settings-heading-<%= @project.id %>"
      data-project-taxonomies-target="settingsDialog"
      data-action="click->project-taxonomies#onSettingsDialogBackdrop"
    >
      <div class="bundle-edit-dialog-panel bundle-edit-dialog-panel--taxonomy-settings-modal">
        <button
          type="button"
          class="bundle-edit-dialog-close"
          data-action="click->project-taxonomies#closeTaxonomySettings"
          aria-label="Close"
        >
          ×
        </button>
        <div class="project-settings-modal-body taxonomy-settings-modal-body flex min-h-0 flex-1 flex-col overflow-hidden">
          <div class="taxonomy-settings-modal-header">
            <h2
              id="taxonomy-settings-heading-<%= @project.id %>"
              class="m-0 text-xl font-extrabold tracking-tight text-prompt-heading"
            >
              Taxonomy Settings
            </h2>
          </div>
          <div
            class="taxonomy-settings-modal-content mt-4 min-h-0 flex-1 overflow-y-auto"
            data-project-taxonomies-target="settingsDialogBody"
          ></div>
          <div class="taxonomy-settings-modal-footer mt-6 border-t border-gray-200 pt-4 dark:border-gray-700">
            <button
              type="button"
              class="prompt-btn-secondary border-red-200 bg-red-50 text-red-800 hover:bg-red-100 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200 dark:hover:bg-red-950/70"
              data-project-taxonomies-target="settingsDialogDeleteButton"
              data-action="click->project-taxonomies#deleteTaxonomy"
            >
              Delete taxonomy
            </button>
          </div>
        </div>
      </div>
    </dialog>

    <dialog
      class="project-delete-confirm-dialog rounded-xl border border-gray-200 bg-white p-5 shadow-xl dark:border-gray-600 dark:bg-gray-800"
      aria-labelledby="taxonomy-bundle-settings-heading-<%= @project.id %>"
      data-project-taxonomies-target="bundleSettingsDialog"
      data-action="click->project-taxonomies#onBundleSettingsDialogBackdrop"
    >
      <h3 id="taxonomy-bundle-settings-heading-<%= @project.id %>" class="m-0 mb-2 text-base font-semibold text-prompt-heading">
        Remove taxonomy assignments?
      </h3>
      <p class="m-0 mb-4 text-sm text-prompt-heading" data-project-taxonomies-target="bundleSettingsDialogMessage"></p>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          class="prompt-btn-secondary border-red-200 bg-red-600 px-3 py-2 text-[0.85rem] text-white hover:bg-red-700 dark:border-red-900 dark:bg-red-700 dark:hover:bg-red-600"
          data-action="click->project-taxonomies#confirmBundleSettingsDialog"
        >
          Change &amp; Delete
        </button>
        <button
          type="button"
          class="prompt-btn-secondary px-3 py-2 text-[0.85rem]"
          data-action="click->project-taxonomies#cancelBundleSettingsDialog"
        >
          Cancel
        </button>
      </div>
    </dialog>
  </section>

  <div class="project-settings-modal-footer mt-8 border-t border-gray-200 pt-5 dark:border-gray-700">
    <button
      type="button"
      class="prompt-btn-secondary border-red-200 bg-red-50 text-red-800 hover:bg-red-100 dark:border-red-900/50 dark:bg-red-950/40 dark:text-red-200 dark:hover:bg-red-950/70"
      data-action="click->project-settings-modal#openDeleteConfirm"
    >
      Delete Project
    </button>
  </div>
</div>

<dialog
  class="project-delete-confirm-dialog rounded-xl border border-gray-200 bg-white p-5 shadow-xl dark:border-gray-600 dark:bg-gray-800"
  data-project-settings-modal-target="deleteConfirmDialog"
  data-action="click->project-settings-modal#stopDeleteDialogBackdrop"
>
  <p class="m-0 mb-4 text-sm font-medium text-prompt-heading">
    Delete project “<%= @project.name %>”? This cannot be undone.
  </p>
  <div class="flex flex-wrap gap-2">
    <%= button_to "Yes, delete",
                  project_path(@project),
                  method: :delete,
                  class: "prompt-btn-secondary border-red-200 bg-red-600 px-3 py-2 text-[0.85rem] text-white hover:bg-red-700 dark:border-red-900 dark:bg-red-700 dark:hover:bg-red-600",
                  data: { turbo_frame: "_top" } %>
    <button
      type="button"
      class="prompt-btn-secondary px-3 py-2 text-[0.85rem]"
      data-action="click->project-settings-modal#closeDeleteConfirm"
    >
      No
    </button>
  </div>
</dialog>
