<% content_for :title, "#{@project.name} · Settings" %>

<div class="mx-auto box-border max-w-[640px] px-5 pb-[calc(2rem+env(safe-area-inset-bottom,0))] pt-8">
  <header class="mb-7">
    <h1 class="mb-1.5 text-[1.65rem] font-extrabold tracking-tight text-prompt-heading">
      Project settings
    </h1>
    <p class="m-0 text-base font-semibold text-prompt-muted"><%= @project.name %></p>
  </header>

  <%= form_with model: @project, url: project_path(@project), method: :patch, class: "grid gap-[1.1rem]" do |f| %>
    <%= hidden_field_tag :settings_form, "1" %>

    <% if @project.errors.any? %>
      <section class="errors !mb-0">
        <h2>Unable to save settings</h2>
        <ul>
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <div class="field grid gap-1.5">
      <%= f.label :name, "Name", class: "text-[0.85rem] font-semibold text-prompt-label" %>
      <%= f.text_field :name,
                       required: true,
                       autocomplete: "off",
                       class:
                         "box-border w-full rounded-lg border border-prompt-field-border px-[0.65rem] py-2.5 text-[0.95rem]" %>
    </div>

    <div class="field grid gap-1.5">
      <%= f.label :description, "Description", class: "text-[0.85rem] font-semibold text-prompt-label" %>
      <%= f.text_area :description,
                      rows: 5,
                      class:
                        "box-border min-h-[6rem] w-full resize-y rounded-lg border border-prompt-field-border px-[0.65rem] py-2.5 font-[inherit] text-[0.95rem] leading-snug",
                      placeholder: "Optional notes about this project…" %>
    </div>

    <div class="flex flex-wrap items-center gap-2 pt-1">
      <%= f.submit "Save settings", class: "prompt-btn-primary" %>
      <%= link_to "Cancel",
                  projects_path,
                  class: "prompt-btn-secondary inline-flex items-center justify-center no-underline" %>
      <%= link_to "Open project",
                  open_project_path(@project),
                  class: "prompt-btn-secondary inline-flex items-center justify-center no-underline" %>
    </div>
  <% end %>
</div>
