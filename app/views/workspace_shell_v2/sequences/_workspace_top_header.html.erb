<header
  class="sticky top-0 z-50 border-b border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800"
  aria-label="Project workspace"
>
  <div
    class="mx-auto grid max-w-[120rem] grid-cols-1 items-center gap-x-4 gap-y-3 px-4 py-3 md:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)]"
  >
    <div class="min-w-0 justify-self-start">
      <%= link_to "<< all projects",
                  projects_path,
                  class:
                    "block text-sm font-semibold text-blue-700 no-underline hover:underline dark:text-blue-400" %>
      <h1 class="truncate text-base font-semibold text-gray-900 dark:text-white md:text-lg">
        <%= @project.name.to_s.truncate(80) %>
      </h1>
    </div>

    <div class="justify-self-center md:order-none md:justify-self-center" role="presentation">
      <% base = workspace_editor_redirect_options.except(:workspace_mode) %>
      <% if @sequence.bundle? %>
        <% first_gen = @project.sequences.generative_sequences.order(:position).first %>
        <% browsing_href =
             if first_gen
               edit_project_sequence_path(@project, first_gen, **base.merge(workspace_mode: :browsing, sidebar: "sequences"))
             else
               open_project_path(@project, **workspace_editor_redirect_options.slice(:workspace_shell))
             end %>
        <% sequencing_href = edit_project_bundle_path(@project, @sequence, **base) %>
      <% else %>
        <% browsing_href = edit_project_sequence_path(@project, @sequence, **base.merge(workspace_mode: :browsing)) %>
        <% sequencing_href = edit_project_sequence_path(@project, @sequence, **base) %>
      <% end %>
      <% tab_active =
           "inline-block rounded-t-lg border-b-2 border-blue-600 px-4 py-2 text-sm font-medium text-blue-600 no-underline dark:border-blue-500 dark:text-blue-400" %>
      <% tab_inactive =
           "inline-block rounded-t-lg border-b-2 border-transparent px-4 py-2 text-sm font-medium text-gray-500 no-underline hover:border-gray-300 hover:text-gray-700 dark:text-gray-400 dark:hover:border-gray-500 dark:hover:text-gray-200" %>
      <nav class="flex flex-wrap justify-center gap-1 border-b border-gray-100 dark:border-gray-700/80 md:border-b-0" aria-label="Workspace mode">
        <% if workspace_browsing? %>
          <%= link_to "Sequencing", sequencing_href, class: tab_inactive, role: "tab" %>
          <%= link_to "Browsing",
                      browsing_href,
                      class: tab_active,
                      role: "tab",
                      aria: { current: "page" } %>
        <% else %>
          <%= link_to "Sequencing",
                      sequencing_href,
                      class: tab_active,
                      role: "tab",
                      aria: { current: "page" } %>
          <%= link_to "Browsing", browsing_href, class: tab_inactive, role: "tab" %>
        <% end %>
      </nav>
    </div>

    <div class="flex min-w-0 flex-shrink-0 flex-wrap items-center justify-end gap-2 justify-self-end">
      <div
        class="inline-flex rounded-lg shadow-sm"
        role="group"
        aria-label="Editor mode"
        data-controller="sequence-list-mode"
      >
        <button
          type="button"
          class="-mr-px inline-flex items-center justify-center rounded-l-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-500"
          data-sequence-list-mode-target="modeReadonly"
          data-mode="readonly"
          data-action="sequence-list-mode#setMode"
          aria-pressed="true"
          title="Read-only"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span class="sr-only">Read-only</span>
        </button>
        <button
          type="button"
          class="inline-flex items-center justify-center rounded-r-lg border border-gray-200 bg-white px-3 py-2 text-sm font-medium text-gray-900 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-500"
          data-sequence-list-mode-target="modeEdit"
          data-mode="edit"
          data-action="sequence-list-mode#setMode"
          aria-pressed="false"
          title="Edit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          <span class="sr-only">Edit</span>
        </button>
      </div>
      <div
        class="inline-flex rounded-lg shadow-sm ring-1 ring-gray-200 dark:ring-gray-600"
        role="group"
        aria-label="Workspace text size"
      >
        <button
          type="button"
          class="-mr-px inline-flex min-w-[2.25rem] items-center justify-center rounded-l-lg border border-gray-200 bg-white px-2 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-500"
          data-workspace-font-size-target="tierSm"
          data-action="workspace-font-size#setSize"
          data-workspace-font-size-size-param="sm"
          aria-pressed="false"
          title="Smaller text in workspace content"
          aria-label="Smaller workspace text"
        >
          A−
        </button>
        <button
          type="button"
          class="-mr-px inline-flex min-w-[2.25rem] items-center justify-center border border-gray-200 bg-white px-2 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-500"
          data-workspace-font-size-target="tierMd"
          data-action="workspace-font-size#setSize"
          data-workspace-font-size-size-param="md"
          aria-pressed="true"
          title="Default text size in workspace content"
          aria-label="Default workspace text size"
        >
          A
        </button>
        <button
          type="button"
          class="inline-flex min-w-[2.25rem] items-center justify-center rounded-r-lg border border-gray-200 bg-white px-2 py-2 text-sm font-semibold text-gray-900 hover:bg-gray-50 focus:z-10 focus:outline-none focus:ring-2 focus:ring-gray-300 dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:hover:bg-gray-700 dark:focus:ring-gray-500"
          data-workspace-font-size-target="tierLg"
          data-action="workspace-font-size#setSize"
          data-workspace-font-size-size-param="lg"
          aria-pressed="false"
          title="Larger text in workspace content"
          aria-label="Larger workspace text"
        >
          A+
        </button>
      </div>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-lg p-2 text-sm font-medium text-gray-500 hover:bg-gray-100 focus:z-10 focus:outline-none focus:ring-4 focus:ring-gray-300 dark:text-gray-400 dark:hover:bg-gray-700 dark:focus:ring-gray-600"
        data-workspace-assistant-toggle-target="button"
        data-action="workspace-assistant-toggle#toggle"
        aria-expanded="true"
        aria-controls="workspace-panel-assistant"
        aria-label="Hide assistant panel"
        title="Hide assistant panel"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <circle cx="12" cy="12" r="12" fill="#111827" />
          <rect x="5.25" y="5.5" width="13.5" height="9" rx="2.25" fill="#fff" />
          <path fill="#fff" d="M8.4 14.25h2.05l-0.95 3.35a.42.42 0 0 1-.8.05l-0.3-3.4z" />
        </svg>
        <span class="sr-only">Toggle assistant panel</span>
      </button>
    </div>
  </div>
</header>
