<% content_for :title, "#{@sequence.title.presence || "Bundle"} · #{@project.name}" %>

<div class="workspace-shell workspace-shell--three-pane<%= " workspace-shell--fabric" if workspace_fabric? %>"
     data-controller="workspace-assistant-toggle workspace-font-size">
  <%= render "sequences/workspace_top_header" %>
  <div class="workspace <%= workspace_fabric? ? "workspace--one-pane" : "workspace--three-pane" %>"
       data-controller="workspace-pane-resize"
       data-workspace-font-size-target="scaleRoot"
       data-workspace-assistant-toggle-target="workspace">
  <% if workspace_fabric? %>
    <%= render "sequences/fabric_workspace_main" %>
  <% else %>
  <%= render "sequences/weave_panel" %>

  <div class="workspace-middle-column">
    <%= render "sequences/workspace_pane_resize_handles" %>
    <%= render "sequences/workspace_work_panel" %>
  </div>

  <%= render "sequences/workspace_assistant_panel" %>
  <% end %>
  </div>
</div>
