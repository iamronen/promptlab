<% modal_mode = local_assigns.fetch(:modal, false) %>
<% thread_panel_editor_embed = local_assigns.fetch(:thread_panel_editor_embed, false) %>
<% editor_form_data = { sequence_editor_target: "form", action: "submit->sequence-editor#syncEditorsBeforeSubmit" } %>
<% editor_form_data[:turbo_frame] = "_top" if modal_mode %>
<% if modal_mode && thread_panel_editor_embed %>
<div class="thread-strand-sequence-container thread-editor-sequence bundle-thread-shell-root"
     data-controller="thread-editor-body-collapse"
     data-thread-editor-body-collapse-expanded-value="true">
<% end %>
    <main
      class="sequence-editor sequence-editor--bundle sequence-editor--readonly<%= " sequence-editor--modal" if modal_mode %>"
      data-controller="sequence-editor"
      data-sequence-editor-readonly-value="true"
      data-sequence-editor-default-title-value="<%= Sequence::BUNDLE_DEFAULT_TITLE %>"
      data-sequence-editor-pipeline-mode-value="true"
      data-sequence-editor-bundle-id-value="<%= @sequence.id %>"
      data-sequence-editor-pipeline-create-sequence-url-value="<%= create_pipeline_sequence_project_bundle_path(@project, @sequence) %>"
      <% if thread_panel_editor_embed && @selected_weave_thread_id.present? %>
      data-sequence-editor-unbundle-project-id-value="<%= @project.id %>"
      data-sequence-editor-unbundle-thread-id-value="<%= @selected_weave_thread_id %>"
      <% end %>
    >
      <%= form_with model: @sequence,
                    url: project_bundle_path(@project, @sequence),
                    method: :patch,
                    html: { id: "sequence-edit-form", class: "sequence-form", data: editor_form_data } do |f| %>
        <% if @selected_weave_thread_id.present? %>
          <%= hidden_field_tag :weave_thread, @selected_weave_thread_id %>
        <% end %>
        <% if @thread_panel_partner_thread.present? %>
          <%= hidden_field_tag :thread_partner, @thread_panel_partner_thread.id %>
        <% end %>
        <% if modal_mode && params[:redirect_to].present? %>
          <%= hidden_field_tag :redirect_to, params[:redirect_to] %>
        <% end %>
        <% if workspace_mode_param.present? %>
          <%= hidden_field_tag :workspace_mode, workspace_mode_param %>
        <% end %>
        <% if @sequence.errors.any? %>
          <section class="errors prompt-form-errors">
            <h2>Unable to save bundle</h2>
            <ul>
              <% @sequence.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </section>
        <% end %>

        <%# Preserve prerequisites when the editor UI for them is hidden. %>
        <%= hidden_field_tag "sequence[prerequisite_bundle_ids][]", "" %>
        <% @sequence.prerequisite_bundle_ids.each do |bid| %>
          <%= hidden_field_tag "sequence[prerequisite_bundle_ids][]", bid %>
        <% end %>

        <% if thread_panel_editor_embed %>
          <%= f.hidden_field :intent %>
          <header class="bundle-thread-editor-bundle-title-row bundle-thread-editor-bundle-title-row--with-thread-body-toggle">
            <button
              type="button"
              class="thread-editor-sequence-body-toggle prompt-thread-panel-icon-btn"
              data-thread-editor-body-collapse-target="toggle"
              data-action="click->thread-editor-body-collapse#toggle"
              aria-expanded="true"
              title="Show or hide pipeline editors"
              aria-label="Show or hide generative sequences in this bundle"
            >
              <svg class="thread-editor-body-collapse-chevron" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="field field--sequence-title bundle-thread-editor-bundle-title-field">
              <%= f.text_field :title,
                               required: true,
                               autocomplete: "off",
                               class: "sequence-title-input bundle-pipeline-bundle-title-input",
                               aria: { label: "Bundle title" },
                               data: {
                                 sequence_editor_target: "titleInput",
                                 action:
                                   "focus->sequence-editor#selectAllIfDefault input->sequence-editor#markAutosaveDirtyFromInput blur->sequence-editor#restoreDefaultIfEmpty blur->sequence-editor#autosaveOnMetaBlur"
                               } %>
            </div>
          </header>
        <% else %>
          <%= f.hidden_field :title %>
          <%= f.hidden_field :intent %>
        <% end %>

        <section class="steps-section bundle-pipeline-section<%= " bundle-pipeline-section--thread-embed-collapsible thread-editor-collapsible-body" if thread_panel_editor_embed %>">
          <% unless thread_panel_editor_embed %>
          <h3 class="bundle-pipeline-heading">Generative sequence pipeline</h3>
          <p class="bundle-pipeline-hint bundle-pipeline-hint--edit">Ordered steps reference generative sequences in this project.</p>
          <% end %>
          <div class="steps-list bundle-pipeline-steps-list" data-editor-kind="bundle_pipeline_slots_list" data-sequence-editor-target="pipelineStepsList">
            <% @sequence.ordered_steps.each_with_index do |step_row, index| %>
              <% pipeline_ord = index + 1 %>
              <% child = step_row.sequence_id.present? ? @pipeline_children_by_id[step_row.sequence_id] : nil %>
              <div
                class="bundle-pipeline-row<%= " thread-editor-bundle-slot" if thread_panel_editor_embed %>"
                draggable="false"
                data-editor-kind="bundle_pipeline_slot"
                data-sequence-editor-target="pipelineStepRow"
                <% if step_row.sequence_id.present? %>id="thread-bundle-<%= @sequence.id %>-seq-<%= step_row.sequence_id %>"<% end %>
                <% if step_row.sequence_id.present? %>data-bundle-pipeline-seq-id="<%= step_row.sequence_id %>"<% end %>
              >
                <% unless thread_panel_editor_embed %>
                <div class="step-order-rail" aria-label="Reorder pipeline step">
                  <button type="button" class="step-order-btn" title="Move step up" data-step-control="up" data-action="sequence-editor#moveUp">
                    <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 6L6 2l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button
                    type="button"
                    class="step-order-btn drag-handle"
                    title="Drag to reorder"
                    aria-label="Drag to reorder"
                    data-action="mousedown->sequence-editor#armDrag mouseup->sequence-editor#disarmDrag mouseleave->sequence-editor#disarmDrag"
                  >
                    <svg class="drag-grip-icon" xmlns="http://www.w3.org/2000/svg" width="17" height="8" viewBox="0 0 20 10" fill="none" aria-hidden="true">
                      <circle cx="2.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="2.5" r="1.2" fill="currentColor"/>
                      <circle cx="2.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="7.5" r="1.2" fill="currentColor"/>
                    </svg>
                  </button>
                  <button type="button" class="step-order-btn" title="Move step down" data-step-control="down" data-action="sequence-editor#moveDown">
                    <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 2l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
                <% end %>
                <% if thread_panel_editor_embed && child %>
                  <% pipeline_step_badge =
                       @bundle_thread_strand_position.present? ? "#{@bundle_thread_strand_position}.#{pipeline_ord}" : pipeline_ord.to_s %>
                  <article class="step-card bundle-pipeline-step-card bundle-pipeline-step-card--thread-editor-unified">
                    <span class="step-hidden-fields" aria-hidden="true">
                      <%= hidden_field_tag "sequence[steps_attributes][#{index}][position]", step_row.position, id: false, data: { sequence_editor_target: "positionInput" } %>
                      <%= hidden_field_tag "sequence[steps_attributes][#{index}][_destroy]", "false", id: false, data: { sequence_editor_target: "destroyInput" } %>
                    </span>
                    <div
                      class="bundle-pipeline-thread-editor-child-shell<%= " bundle-pipeline-thread-editor-child-shell--has-thread-branch-band" if child&.anchors_child_threads? %>"
                      <% if child&.anchors_child_threads? %>
                      style="--thread-branch-link-count: <%= child.anchored_child_threads_ordered.size %>"
                      <% end %>
                    >
                      <%= render "sequences/bundle_pipeline_thread_child_leading_strip",
                                 step_badge_text: pipeline_step_badge,
                                 render_child_threads_indicator: child&.anchors_child_threads?,
                                 indicator_sequence: child %>
                      <div
                      class="thread-strand-sequence-container thread-editor-sequence bundle-pipeline-thread-child-sequence bundle-pipeline-thread-child-sequence-column"
                      data-controller="thread-editor-body-collapse"
                      data-thread-editor-body-collapse-expanded-value="true"
                    >
                        <%= hidden_field_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                             child.id,
                                             id: nil,
                                             class: "bundle-pipeline-sequence-id-field",
                                             autocomplete: "off" %>
                        <%= render "sequences/thread_editor_sequence_meta",
                                   variant: :bundle_child_tags,
                                   title_field_name: "nested_sequences[#{child.id}][title]",
                                   title_value: child.title,
                                   intent_field_name: "nested_sequences[#{child.id}][intent]",
                                   intent_value: child.intent,
                                   thread_panel_editor_embed: thread_panel_editor_embed,
                                   taxonomy_subject: child %>
                        <section class="steps-section bundle-pipeline-nested-thread-steps thread-editor-collapsible-body">
                          <%= render "sequences/nested_generative_steps",
                                     child_sequence: child,
                                     form_field_prefix: "nested_sequences[#{child.id}]",
                                     thread_panel_editor_embed: thread_panel_editor_embed,
                                     suppress_sequence_wrapper: true,
                                     suppress_footer_thread_branch_tail: true %>
                        </section>
                        <% if child&.anchors_child_threads? %>
                          <div class="bundle-pipeline-thread-child-sequence__thread-branch-band thread-editor-collapsible-body">
                            <%= render "sequences/thread_branch_strand_bridge_band",
                                       indicator_sequence: child,
                                       layout: :bundle_nested,
                                       insert_after_panel_thread_id: @workspace_thread&.id %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </article>

                <% elsif thread_panel_editor_embed %>
                  <article class="step-card bundle-pipeline-step-card bundle-pipeline-step-card--thread-editor-empty-slot">
                    <span class="step-hidden-fields" aria-hidden="true">
                      <%= hidden_field_tag "sequence[steps_attributes][#{index}][position]", step_row.position, id: false, data: { sequence_editor_target: "positionInput" } %>
                      <%= hidden_field_tag "sequence[steps_attributes][#{index}][_destroy]", "false", id: false, data: { sequence_editor_target: "destroyInput" } %>
                    </span>
                    <div class="step-content-area bundle-step-picker-area" data-action="click->sequence-editor#activateStep">
                      <%= select_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                     options_for_select(
                                       [["— Select sequence —", ""]] + @pipeline_sequences.map { |s| [s.title.to_s.truncate(80), s.id] } + [["+ Create new sequence…", "__new__"]],
                                       step_row.sequence_id
                                     ),
                                     id: nil,
                                     class: "bundle-step-select bundle-pipeline-sequence-id-field",
                                     data: {
                                       sequence_editor_target: "sequenceSelect",
                                       action: "change->sequence-editor#pipelineSequenceSelectChanged"
                                     } %>
                    </div>
                  </article>

                <% else %>
                <% if modal_mode %>
                <div class="thread-strand-sequence-container">
                <% end %>
                <article class="step-card bundle-pipeline-step-card">
                  <span class="step-hidden-fields" aria-hidden="true">
                    <%= hidden_field_tag "sequence[steps_attributes][#{index}][position]", step_row.position, id: false, data: { sequence_editor_target: "positionInput" } %>
                    <%= hidden_field_tag "sequence[steps_attributes][#{index}][_destroy]", "false", id: false, data: { sequence_editor_target: "destroyInput" } %>
                  </span>
                  <% unless thread_panel_editor_embed %>
                  <div class="step-number-area bundle-pipeline-step-number">
                    <strong class="step-label" data-sequence-editor-target="stepLabel"><%= step_row.position %></strong>
                  </div>

                  <div class="step-actions-area bundle-pipeline-actions">
                    <button
                      type="button"
                      class="tool-button step-toolbox-delete"
                      title="Delete step"
                      aria-label="Delete step"
                      data-action="sequence-editor#deleteStep"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                    </button>
                    <div class="step-menu-wrap" data-sequence-editor-target="menuWrap">
                      <button type="button" class="tool-button menu-trigger" title="Step actions" data-action="click->sequence-editor#toggleMenu">⋯</button>
                      <div class="step-menu" hidden data-sequence-editor-target="menu">
                        <button type="button" data-action="sequence-editor#addStepBefore">Add step before</button>
                        <button type="button" data-action="sequence-editor#addStepAfter">Add step after</button>
                        <button type="button" data-action="sequence-editor#duplicateStep">Duplicate step</button>
                        <button type="button" data-action="sequence-editor#deleteStep">Delete step</button>
                      </div>
                    </div>
                  </div>
                  <% end %>

                  <% segment_title = child&.title.presence || step_row.title.presence || "Generative sequence" %>
                  <div class="bundle-segment-readonly bundle-segment-document bundle-readonly-sequence-shell">
                    <div class="bundle-readonly-sequence-layout">
                      <% unless thread_panel_editor_embed %>
                      <div class="step-number-area bundle-readonly-sequence-index" aria-hidden="true">
                        <strong class="step-label"><%= pipeline_ord %></strong>
                      </div>
                      <% end %>
                      <div class="bundle-readonly-sequence-content">
                        <h4 class="bundle-segment-heading"><%= segment_title %></h4>
                        <% if child&.intent.present? %>
                          <p class="bundle-readonly-sequence-intent"><%= child.intent %></p>
                        <% end %>
                        <% if child %>
                          <% child.ordered_steps.each_with_index do |sr, step_index| %>
                            <div class="bundle-readonly-nested-step-row">
                              <% unless thread_panel_editor_embed %>
                              <div class="step-number-area bundle-readonly-nested-index" aria-hidden="true">
                                <strong class="step-label step-label--compound"><%= pipeline_ord %>.<%= step_index + 1 %></strong>
                              </div>
                              <% end %>
                              <div class="bundle-readonly-nested-step-body">
                                <div class="bundle-segment-step-prose rich-editor"><%= sr.content.to_s.html_safe %></div>
                              </div>
                            </div>
                          <% end %>
                        <% elsif step_row.sequence_id.present? %>
                          <p class="bundle-segment-missing">This sequence is no longer available.</p>
                        <% else %>
                          <p class="bundle-segment-missing bundle-segment-missing--empty-slot">No sequence selected.</p>
                        <% end %>
                      </div>
                    </div>
                  </div>

                  <div class="bundle-pipeline-edit-stack">
                    <div class="step-content-area bundle-step-picker-area" data-action="click->sequence-editor#activateStep">
                      <% if child %>
                        <%= hidden_field_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                             child.id,
                                             id: nil,
                                             class: "bundle-pipeline-sequence-id-field",
                                             autocomplete: "off" %>
                        <div class="bundle-pipeline-child-meta">
                          <div class="field field--sequence-title">
                            <%= text_field_tag "nested_sequences[#{child.id}][title]",
                                               child.title,
                                               required: true,
                                               autocomplete: "off",
                                               class: "sequence-title-input bundle-pipeline-child-title-input",
                                               aria: { label: "Generative sequence title" } %>
                          </div>
                          <div class="field field--sequence-intent">
                            <%= text_area_tag "nested_sequences[#{child.id}][intent]",
                                              child.intent,
                                              required: true,
                                              rows: 1,
                                              autocomplete: "off",
                                              class: "sequence-intent-input bundle-pipeline-child-intent-input",
                                              aria: { label: "Generative sequence intent" } %>
                          </div>
                        </div>
                      <% else %>
                        <%= select_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                       options_for_select(
                                         [["— Select sequence —", ""]] + @pipeline_sequences.map { |s| [s.title.to_s.truncate(80), s.id] } + [["+ Create new sequence…", "__new__"]],
                                         step_row.sequence_id
                                       ),
                                       id: nil,
                                       class: "bundle-step-select bundle-pipeline-sequence-id-field",
                                       data: {
                                         sequence_editor_target: "sequenceSelect",
                                         action: "change->sequence-editor#pipelineSequenceSelectChanged"
                                       } %>
                      <% end %>
                    </div>

                    <% if child %>
                      <div class="bundle-nested-editor-wrap">
                        <%= render "sequences/nested_generative_steps",
                                   child_sequence: child,
                                   form_field_prefix: "nested_sequences[#{child.id}]",
                                   thread_panel_editor_embed: thread_panel_editor_embed,
                                   suppress_footer_thread_branch_tail: true %>
                      </div>
                    <% end %>
                  </div>
                </article>
                <% if modal_mode %>
                </div>
                <% end %>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="steps-footer bundle-pipeline-footer">
            <button type="button" class="prompt-btn-secondary add-step-button text-sm" data-action="sequence-editor#addStep">Add Sequence</button>
          </div>
        </section>

      <% end %>

      <template data-sequence-editor-target="sequenceOptionsTemplate">
        <option value="">— Select sequence —</option>
        <% @pipeline_sequences.each do |ps| %>
          <option value="<%= ps.id %>"><%= ps.title.to_s.truncate(80) %></option>
        <% end %>
        <option value="__new__">+ Create new sequence…</option>
      </template>

      <template data-sequence-editor-target="stepTemplate">
        <% if thread_panel_editor_embed %>
        <div class="bundle-pipeline-row thread-editor-bundle-slot" draggable="false" data-editor-kind="bundle_pipeline_slot" data-sequence-editor-target="pipelineStepRow">
          <article class="step-card bundle-pipeline-step-card bundle-pipeline-step-card--thread-editor-empty-slot">
            <span class="step-hidden-fields" aria-hidden="true">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][position]" value="0" data-sequence-editor-target="positionInput">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][_destroy]" value="false" data-sequence-editor-target="destroyInput">
            </span>
            <div class="step-content-area bundle-step-picker-area" data-action="click->sequence-editor#activateStep">
              <select
                name="sequence[steps_attributes][NEW_RECORD][sequence_id]"
                class="bundle-step-select bundle-pipeline-sequence-id-field"
                data-sequence-editor-target="sequenceSelect"
                data-action="change->sequence-editor#pipelineSequenceSelectChanged"
              ></select>
            </div>
          </article>
        </div>
        <% else %>
        <div class="bundle-pipeline-row" draggable="false" data-editor-kind="bundle_pipeline_slot" data-sequence-editor-target="pipelineStepRow">
          <div class="step-order-rail" aria-label="Reorder pipeline step">
            <button type="button" class="step-order-btn" title="Move step up" data-step-control="up" data-action="sequence-editor#moveUp">
              <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 6L6 2l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button
              type="button"
              class="step-order-btn drag-handle"
              title="Drag to reorder"
              aria-label="Drag to reorder"
              data-action="mousedown->sequence-editor#armDrag mouseup->sequence-editor#disarmDrag mouseleave->sequence-editor#disarmDrag"
            >
              <svg class="drag-grip-icon" xmlns="http://www.w3.org/2000/svg" width="17" height="8" viewBox="0 0 20 10" fill="none" aria-hidden="true">
                <circle cx="2.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="2.5" r="1.2" fill="currentColor"/>
                <circle cx="2.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="7.5" r="1.2" fill="currentColor"/>
              </svg>
            </button>
            <button type="button" class="step-order-btn" title="Move step down" data-step-control="down" data-action="sequence-editor#moveDown">
              <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 2l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
             </button>
          </div>
          <article class="step-card bundle-pipeline-step-card">
            <span class="step-hidden-fields" aria-hidden="true">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][position]" value="0" data-sequence-editor-target="positionInput">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][_destroy]" value="false" data-sequence-editor-target="destroyInput">
            </span>
            <div class="step-number-area bundle-pipeline-step-number">
              <strong class="step-label" data-sequence-editor-target="stepLabel">Step</strong>
            </div>

            <div class="step-actions-area bundle-pipeline-actions">
              <button
                type="button"
                class="tool-button step-toolbox-delete"
                title="Delete step"
                aria-label="Delete step"
                data-action="sequence-editor#deleteStep"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
              <div class="step-menu-wrap" data-sequence-editor-target="menuWrap">
                <button type="button" class="tool-button menu-trigger" title="Step actions" data-action="click->sequence-editor#toggleMenu">⋯</button>
                <div class="step-menu" hidden data-sequence-editor-target="menu">
                  <button type="button" data-action="sequence-editor#addStepBefore">Add step before</button>
                  <button type="button" data-action="sequence-editor#addStepAfter">Add step after</button>
                  <button type="button" data-action="sequence-editor#duplicateStep">Duplicate step</button>
                  <button type="button" data-action="sequence-editor#deleteStep">Delete step</button>
                </div>
              </div>
            </div>

            <div class="bundle-segment-readonly bundle-segment-document bundle-readonly-sequence-shell">
              <div class="bundle-readonly-sequence-layout">
                <div class="step-number-area bundle-readonly-sequence-index" aria-hidden="true">
                  <strong class="step-label">1</strong>
                </div>
                <div class="bundle-readonly-sequence-content">
                  <h4 class="bundle-segment-heading">Generative sequence</h4>
                  <p class="bundle-segment-missing bundle-segment-missing--empty-slot">No sequence selected.</p>
                </div>
              </div>
            </div>

            <div class="bundle-pipeline-edit-stack">
              <div class="step-content-area bundle-step-picker-area" data-action="click->sequence-editor#activateStep">
                <select
                  name="sequence[steps_attributes][NEW_RECORD][sequence_id]"
                  class="bundle-step-select bundle-pipeline-sequence-id-field"
