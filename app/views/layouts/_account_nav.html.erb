<div class="flex flex-wrap items-center justify-end gap-3 text-sm">
  <% if user_signed_in? %>
    <span class="hidden max-w-[14rem] truncate text-gray-600 dark:text-gray-300 sm:inline" title="<%= current_user.email %>">
      <%= current_user.email %>
    </span>
    <%= link_to "Account",
                edit_user_registration_path,
                class: "font-medium text-prompt-accent no-underline hover:underline dark:text-blue-400" %>
    <%= button_to "Sign out",
                  destroy_user_session_path,
                  method: :delete,
                  class:
                    "rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-gray-700 hover:bg-gray-50 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" %>
  <% else %>
    <%= link_to "Sign in",
                new_user_session_path,
                class: "font-medium text-gray-700 no-underline hover:text-prompt-accent dark:text-gray-300 dark:hover:text-blue-400" %>
    <%= link_to "Sign up",
                new_user_registration_path,
                class:
                  "rounded-lg bg-prompt-accent px-3 py-1.5 font-medium text-white no-underline hover:opacity-90 dark:bg-blue-600" %>
  <% end %>
</div>
