<% content_for :title, "#{@sequence.title.presence || "Transformation"} · #{@project.name}" %>

<div class="workspace">
  <%= render "sequences/sequence_nav" %>

  <div class="workspace-main">
    <main
      class="sequence-editor sequence-editor--transformation sequence-editor--readonly"
      data-controller="sequence-editor"
      data-sequence-editor-readonly-value="true"
      data-sequence-editor-pipeline-mode-value="true"
      data-sequence-editor-default-title-value="<%= Sequence::TRANSFORMATION_DEFAULT_TITLE %>"
      data-sequence-editor-default-intent-value="<%= Sequence::TRANSFORMATION_DEFAULT_INTENT %>"
      data-sequence-editor-pipeline-create-sequence-url-value="<%= create_pipeline_sequence_project_transformation_path(@project, @sequence) %>"
    >
      <%= form_with model: @sequence,
                    url: project_transformation_path(@project, @sequence),
                    method: :patch,
                    html: { id: "sequence-edit-form", class: "sequence-form" },
                    data: { sequence_editor_target: "form", action: "submit->sequence-editor#syncEditorsBeforeSubmit" } do |f| %>
        <% if @sequence.errors.any? %>
          <section class="errors">
            <h2>Unable to save transformation</h2>
            <ul>
              <% @sequence.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </section>
        <% end %>

        <section class="meta-fields">
          <div class="sequence-heading-row">
            <div class="field field--sequence-title">
              <%= f.text_field :title,
                               required: true,
                               autocomplete: "off",
                               class: "sequence-title-input",
                               aria: { label: "Transformation title" },
                               data: {
                                 sequence_editor_target: "titleInput",
                                 action: "focus->sequence-editor#selectAllIfDefault blur->sequence-editor#restoreDefaultIfEmpty"
                               } %>
            </div>
            <div class="sequence-mode-toggle" role="group" aria-label="Editor mode">
              <button
                type="button"
                class="sequence-mode-btn"
                data-sequence-editor-target="modeReadonly"
                data-mode="readonly"
                data-action="sequence-editor#setMode"
                aria-pressed="true"
                title="Read-only"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              </button>
              <button
                type="button"
                class="sequence-mode-btn"
                data-sequence-editor-target="modeEdit"
                data-mode="edit"
                data-action="sequence-editor#setMode"
                aria-pressed="false"
                title="Edit"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
              </button>
            </div>
          </div>
          <div class="field field--sequence-intent">
            <%= f.text_field :intent,
                             required: true,
                             autocomplete: "off",
                             class: "sequence-intent-input",
                             aria: { label: "Intent" },
                             data: {
                               sequence_editor_target: "intentInput",
                               action: "focus->sequence-editor#selectAllIfDefault blur->sequence-editor#restoreDefaultIfEmpty"
                             } %>
          </div>
        </section>

        <section class="transformation-prerequisites" aria-label="Prerequisite transformations">
          <h3 class="transformation-prerequisites-heading">Prerequisite transformations</h3>
          <div class="transformation-prerequisites-readonly transformation-prerequisites-summary" aria-label="Selected prerequisites">
            <% prereq_selected = @other_transformations.select { |t| @sequence.prerequisite_transformation_ids.include?(t.id) } %>
            <% if prereq_selected.any? %>
              <ul class="transformation-prerequisites-summary-list">
                <% prereq_selected.each do |t| %>
                  <li><%= t.title %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="transformation-prerequisites-summary-empty">None selected.</p>
            <% end %>
          </div>
          <div class="transformation-prerequisites-edit">
            <p class="transformation-prerequisites-hint">Optional. These transformations are treated as dependencies that should be addressed before this one.</p>
            <% if @other_transformations.any? %>
              <div class="transformation-prerequisites-list">
                <%= hidden_field_tag "sequence[prerequisite_transformation_ids][]", "" %>
                <% @other_transformations.each do |t| %>
                  <label class="transformation-prerequisite-option">
                    <%= check_box_tag "sequence[prerequisite_transformation_ids][]",
                                      t.id,
                                      @sequence.prerequisite_transformation_ids.include?(t.id),
                                      id: dom_id(t, :prerequisite) %>
                    <%= t.title.truncate(56) %>
                  </label>
                <% end %>
              </div>
            <% else %>
              <p class="transformation-prerequisites-empty">No other transformations in this project yet.</p>
            <% end %>
          </div>
        </section>

        <section class="steps-section transformation-pipeline-section">
          <h3 class="transformation-pipeline-heading">Generative sequence pipeline</h3>
          <p class="transformation-pipeline-hint transformation-pipeline-hint--edit">Ordered steps reference generative sequences in this project.</p>
          <div class="steps-list transformation-pipeline-steps-list" data-sequence-editor-target="pipelineStepsList">
            <% @sequence.ordered_steps.each_with_index do |step_row, index| %>
              <% pipeline_ord = index + 1 %>
              <% child = step_row.sequence_id.present? ? @pipeline_children_by_id[step_row.sequence_id] : nil %>
              <div
                class="step-row transformation-pipeline-row"
                draggable="false"
                data-sequence-editor-target="pipelineStepRow"
                <% if step_row.sequence_id.present? %>data-transformation-pipeline-seq-id="<%= step_row.sequence_id %>"<% end %>
              >
                <div class="step-order-rail" aria-label="Reorder pipeline step">
                  <button type="button" class="step-order-btn" title="Move step up" data-step-control="up" data-action="sequence-editor#moveUp">
                    <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 6L6 2l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <button
                    type="button"
                    class="step-order-btn drag-handle"
                    title="Drag to reorder"
                    aria-label="Drag to reorder"
                    data-action="mousedown->sequence-editor#armDrag mouseup->sequence-editor#disarmDrag mouseleave->sequence-editor#disarmDrag"
                  >
                    <svg class="drag-grip-icon" xmlns="http://www.w3.org/2000/svg" width="17" height="8" viewBox="0 0 20 10" fill="none" aria-hidden="true">
                      <circle cx="2.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="2.5" r="1.2" fill="currentColor"/>
                      <circle cx="2.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="7.5" r="1.2" fill="currentColor"/>
                    </svg>
                  </button>
                  <button type="button" class="step-order-btn" title="Move step down" data-step-control="down" data-action="sequence-editor#moveDown">
                    <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 2l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
                <article class="step-card transformation-pipeline-step-card">
                  <span class="step-hidden-fields" aria-hidden="true">
                    <%= hidden_field_tag "sequence[steps_attributes][#{index}][position]", step_row.position, id: false, data: { sequence_editor_target: "positionInput" } %>
                    <%= hidden_field_tag "sequence[steps_attributes][#{index}][_destroy]", "false", id: false, data: { sequence_editor_target: "destroyInput" } %>
                  </span>
                  <div class="step-number-area transformation-pipeline-step-number">
                    <strong class="step-label" data-sequence-editor-target="stepLabel"><%= step_row.position %></strong>
                  </div>

                  <div class="step-actions-area transformation-pipeline-actions">
                    <button
                      type="button"
                      class="tool-button step-toolbox-delete"
                      title="Delete step"
                      aria-label="Delete step"
                      data-action="sequence-editor#deleteStep"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                    </button>
                    <div class="step-menu-wrap" data-sequence-editor-target="menuWrap">
                      <button type="button" class="tool-button menu-trigger" title="Step actions" data-action="click->sequence-editor#toggleMenu">⋯</button>
                      <div class="step-menu" hidden data-sequence-editor-target="menu">
                        <button type="button" data-action="sequence-editor#addStepBefore">Add step before</button>
                        <button type="button" data-action="sequence-editor#addStepAfter">Add step after</button>
                        <button type="button" data-action="sequence-editor#duplicateStep">Duplicate step</button>
                        <button type="button" data-action="sequence-editor#deleteStep">Delete step</button>
                      </div>
                    </div>
                  </div>

                  <% segment_title = child&.title.presence || step_row.title.presence || "Generative sequence" %>
                  <div class="transformation-segment-readonly transformation-segment-document transformation-readonly-sequence-shell">
                    <div class="transformation-readonly-sequence-layout">
                      <div class="step-number-area transformation-readonly-sequence-index" aria-hidden="true">
                        <strong class="step-label"><%= pipeline_ord %></strong>
                      </div>
                      <div class="transformation-readonly-sequence-content">
                        <h4 class="transformation-segment-heading"><%= segment_title %></h4>
                        <% if child&.intent.present? %>
                          <p class="transformation-readonly-sequence-intent"><%= child.intent %></p>
                        <% end %>
                        <% if child %>
                          <% child.ordered_steps.each_with_index do |sr, step_index| %>
                            <div class="transformation-readonly-nested-step-row">
                              <div class="step-number-area transformation-readonly-nested-index" aria-hidden="true">
                                <strong class="step-label step-label--compound"><%= pipeline_ord %>.<%= step_index + 1 %></strong>
                              </div>
                              <div class="transformation-readonly-nested-step-body">
                                <div class="transformation-segment-step-prose rich-editor"><%= sr.content.to_s.html_safe %></div>
                              </div>
                            </div>
                          <% end %>
                        <% elsif step_row.sequence_id.present? %>
                          <p class="transformation-segment-missing">This sequence is no longer available.</p>
                        <% else %>
                          <p class="transformation-segment-missing transformation-segment-missing--empty-slot">No sequence selected.</p>
                        <% end %>
                      </div>
                    </div>
                  </div>

                  <div class="transformation-pipeline-edit-stack">
                    <div class="step-content-area transformation-step-picker-area" data-action="click->sequence-editor#activateStep">
                      <% if child %>
                        <%= hidden_field_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                             child.id,
                                             id: nil,
                                             class: "transformation-pipeline-sequence-id-field",
                                             autocomplete: "off" %>
                        <div class="transformation-pipeline-child-meta">
                          <div class="field field--sequence-title">
                            <%= text_field_tag "nested_sequences[#{child.id}][title]",
                                               child.title,
                                               required: true,
                                               autocomplete: "off",
                                               class: "sequence-title-input transformation-pipeline-child-title-input",
                                               aria: { label: "Generative sequence title" } %>
                          </div>
                          <div class="field field--sequence-intent">
                            <%= text_field_tag "nested_sequences[#{child.id}][intent]",
                                               child.intent,
                                               required: true,
                                               autocomplete: "off",
                                               class: "sequence-intent-input transformation-pipeline-child-intent-input",
                                               aria: { label: "Generative sequence intent" } %>
                          </div>
                        </div>
                      <% else %>
                        <%= select_tag "sequence[steps_attributes][#{index}][sequence_id]",
                                       options_for_select(
                                         [["— Select sequence —", ""]] + @pipeline_sequences.map { |s| [s.title.to_s.truncate(80), s.id] } + [["+ Create new sequence…", "__new__"]],
                                         step_row.sequence_id
                                       ),
                                       id: nil,
                                       class: "transformation-step-select transformation-pipeline-sequence-id-field",
                                       data: {
                                         sequence_editor_target: "sequenceSelect",
                                         action: "change->sequence-editor#pipelineSequenceSelectChanged"
                                       } %>
                      <% end %>
                    </div>

                    <% if child %>
                      <div class="transformation-nested-editor-wrap">
                        <%= render "sequences/nested_generative_steps",
                                   child_sequence: child,
                                   form_field_prefix: "nested_sequences[#{child.id}]",
                                   sequence_save_url: project_sequence_path(@project, child) %>
                      </div>
                    <% end %>
                  </div>
                </article>
              </div>
            <% end %>
          </div>

          <div class="steps-footer transformation-pipeline-footer">
            <button type="button" class="secondary-button add-step-button" data-action="sequence-editor#addStep">Add Sequence</button>
          </div>
        </section>

      <% end %>

      <footer class="editor-footer-actions">
        <div class="editor-footer-primary-actions">
          <button
            type="submit"
            form="sequence-edit-form"
            class="primary-button editor-footer-save"
            name="commit"
            value="Save transformation"
            data-disable-with="Save transformation"
          >
            Save transformation
          </button>
          <div class="editor-footer-delete">
            <%= button_to "Delete transformation",
                          project_transformation_path(@project, @sequence),
                          method: :delete,
                          class: "danger-button",
                          form: {
                            data: {
                              turbo_confirm: "Delete this transformation? This cannot be undone."
                            }
                          } %>
          </div>
        </div>
        <button
          type="button"
          class="copy-button editor-footer-copy"
          data-action="sequence-editor#copySequenceAsPrompt"
          data-sequence-editor-target="copyButton"
        >
          Copy as Prompt
        </button>
      </footer>

      <template data-sequence-editor-target="sequenceOptionsTemplate">
        <option value="">— Select sequence —</option>
        <% @pipeline_sequences.each do |ps| %>
          <option value="<%= ps.id %>"><%= ps.title.to_s.truncate(80) %></option>
        <% end %>
        <option value="__new__">+ Create new sequence…</option>
      </template>

      <template data-sequence-editor-target="stepTemplate">
        <div class="step-row transformation-pipeline-row" draggable="false" data-sequence-editor-target="pipelineStepRow">
          <div class="step-order-rail" aria-label="Reorder pipeline step">
            <button type="button" class="step-order-btn" title="Move step up" data-step-control="up" data-action="sequence-editor#moveUp">
              <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 6L6 2l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button
              type="button"
              class="step-order-btn drag-handle"
              title="Drag to reorder"
              aria-label="Drag to reorder"
              data-action="mousedown->sequence-editor#armDrag mouseup->sequence-editor#disarmDrag mouseleave->sequence-editor#disarmDrag"
            >
              <svg class="drag-grip-icon" xmlns="http://www.w3.org/2000/svg" width="17" height="8" viewBox="0 0 20 10" fill="none" aria-hidden="true">
                <circle cx="2.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="2.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="2.5" r="1.2" fill="currentColor"/>
                <circle cx="2.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="7.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="12.5" cy="7.5" r="1.2" fill="currentColor"/><circle cx="17.5" cy="7.5" r="1.2" fill="currentColor"/>
              </svg>
            </button>
            <button type="button" class="step-order-btn" title="Move step down" data-step-control="down" data-action="sequence-editor#moveDown">
              <svg class="step-order-caret" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 12 8" fill="none" aria-hidden="true"><path d="M2 2l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
             </button>
          </div>
          <article class="step-card transformation-pipeline-step-card">
            <span class="step-hidden-fields" aria-hidden="true">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][position]" value="0" data-sequence-editor-target="positionInput">
              <input type="hidden" name="sequence[steps_attributes][NEW_RECORD][_destroy]" value="false" data-sequence-editor-target="destroyInput">
            </span>
            <div class="step-number-area transformation-pipeline-step-number">
              <strong class="step-label" data-sequence-editor-target="stepLabel">Step</strong>
            </div>

            <div class="step-actions-area transformation-pipeline-actions">
              <button
                type="button"
                class="tool-button step-toolbox-delete"
                title="Delete step"
                aria-label="Delete step"
                data-action="sequence-editor#deleteStep"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
              <div class="step-menu-wrap" data-sequence-editor-target="menuWrap">
                <button type="button" class="tool-button menu-trigger" title="Step actions" data-action="click->sequence-editor#toggleMenu">⋯</button>
                <div class="step-menu" hidden data-sequence-editor-target="menu">
                  <button type="button" data-action="sequence-editor#addStepBefore">Add step before</button>
                  <button type="button" data-action="sequence-editor#addStepAfter">Add step after</button>
                  <button type="button" data-action="sequence-editor#duplicateStep">Duplicate step</button>
                  <button type="button" data-action="sequence-editor#deleteStep">Delete step</button>
                </div>
              </div>
            </div>

            <div class="transformation-segment-readonly transformation-segment-document transformation-readonly-sequence-shell">
              <div class="transformation-readonly-sequence-layout">
                <div class="step-number-area transformation-readonly-sequence-index" aria-hidden="true">
                  <strong class="step-label">1</strong>
                </div>
                <div class="transformation-readonly-sequence-content">
                  <h4 class="transformation-segment-heading">Generative sequence</h4>
                  <p class="transformation-segment-missing transformation-segment-missing--empty-slot">No sequence selected.</p>
                </div>
              </div>
            </div>

            <div class="transformation-pipeline-edit-stack">
              <div class="step-content-area transformation-step-picker-area" data-action="click->sequence-editor#activateStep">
                <select
                  name="sequence[steps_attributes][NEW_RECORD][sequence_id]"
                  class="transformation-step-select transformation-pipeline-sequence-id-field"
                  data-sequence-editor-target="sequenceSelect"
                  data-action="change->sequence-editor#pipelineSequenceSelectChanged"
                ></select>
              </div>
            </div>
          </article>
        </div>
      </template>
    </main>
  </div>

  <aside class="workspace-chat-panel" aria-label="Assistant chat">
    <header class="workspace-chat-panel-header">
      <h2 class="workspace-chat-panel-title">Assistant</h2>
    </header>
    <div class="workspace-chat-panel-body">
      <p class="workspace-chat-panel-placeholder">
        Interactive LLM chat will appear here.
      </p>
    </div>
  </aside>
</div>
