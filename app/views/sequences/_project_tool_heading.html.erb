<% base = workspace_editor_redirect_options.except(:workspace_mode) %>
<% if @sequence.bundle? %>
  <% fabric_href = edit_project_bundle_path(@project, @sequence, **base) %>
  <% process_href = edit_project_bundle_path(@project, @sequence, **base.merge(workspace_mode: :process)) %>
  <% settings_href = edit_project_bundle_path(@project, @sequence, **base.merge(workspace_mode: :settings)) %>
<% else %>
  <% fabric_href = edit_project_sequence_path(@project, @sequence, **base) %>
  <% process_href = edit_project_sequence_path(@project, @sequence, **base.merge(workspace_mode: :process)) %>
  <% settings_href = edit_project_sequence_path(@project, @sequence, **base.merge(workspace_mode: :settings)) %>
<% end %>
<% fabric_active = workspace_fabric? %>
<% process_active = workspace_process? %>
<% settings_active = workspace_settings? %>

<div class="tool-heading-bar">
  <div class="tool-heading-bar-spacer" aria-hidden="true"></div>

  <div class="tool-heading-center">
    <h1 class="tool-heading-title">
      Project: <%= @project.name.to_s.truncate(80) %>
    </h1>

    <div class="tool-heading-center-controls">
    <div
      class="prompt-workspace-header-btn-group prompt-workspace-header-btn-group--ring"
      role="group"
      aria-label="Project tool mode"
    >
      <%= link_to "Fabric",
                  fabric_href,
                  class: class_names(
                    "prompt-workspace-header-segment prompt-workspace-header-segment--first no-underline",
                    { "prompt-workspace-header-segment--active" => fabric_active }
                  ),
                  aria: (fabric_active ? { current: "page" } : {}) %>
      <%= link_to "Process",
                  process_href,
                  class: class_names(
                    "prompt-workspace-header-segment prompt-workspace-header-segment--mid no-underline",
                    { "prompt-workspace-header-segment--active" => process_active }
                  ),
                  aria: (process_active ? { current: "page" } : {}) %>
      <%= link_to settings_href,
                  class: class_names(
                    "prompt-workspace-header-segment prompt-workspace-header-segment--last no-underline",
                    { "prompt-workspace-header-segment--active" => settings_active }
                  ),
                  aria: (settings_active ? { current: "page", label: "Project settings" } : { label: "Project settings" }),
                  title: "Project settings" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <span class="sr-only">Project settings</span>
      <% end %>
    </div>

    <% unless workspace_settings? || workspace_process? %>
      <div
        class="prompt-workspace-header-btn-group prompt-workspace-header-btn-group--ring"
        role="group"
        aria-label="Editor mode"
        data-controller="sequence-list-mode"
      >
        <button
          type="button"
          class="prompt-workspace-header-segment prompt-workspace-header-segment--first"
          data-sequence-list-mode-target="modeReadonly"
          data-mode="readonly"
          data-action="sequence-list-mode#setMode"
          aria-pressed="true"
          title="Read-only"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          <span class="sr-only">Read-only</span>
        </button>
        <button
          type="button"
          class="prompt-workspace-header-segment prompt-workspace-header-segment--last"
          data-sequence-list-mode-target="modeEdit"
          data-mode="edit"
          data-action="sequence-list-mode#setMode"
          aria-pressed="false"
          title="Edit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          <span class="sr-only">Edit</span>
        </button>
      </div>
    <% end %>
    </div>
  </div>

  <div class="prompt-workspace-header-toolbar"></div>
</div>
