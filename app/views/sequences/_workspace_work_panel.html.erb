<% editor_return_path = request.fullpath %>
<% q_keep = request.query_parameters.slice("weave_thread", "thread_partner", "open_threads", "sidebar", "editor_mode", "focus_bundle_id", "focus_transformation_id", "workspace_mode", "workspace_shell").symbolize_keys %>
<% embed_query = q_keep.except(:focus_bundle_id, :focus_transformation_id) %>
<% panel_threads = @thread_workspace_open_thread_records.presence || [@genesis_thread].compact %>
<% panel_threads = Array.wrap(@project.sequences.threads.order(:position).first).compact if panel_threads.blank? %>
<% allowed_thread_ids = @project.sequences.threads.pluck(:id) %>
<div
  class="workspace-work-shell h-full min-h-0 flex min-w-0 flex-1 flex-col"
  aria-label="Thread workspace"
  data-controller="thread-workspace"
  data-thread-workspace-project-id-value="<%= @project.id %>"
  data-thread-workspace-allowed-ids-value="<%= allowed_thread_ids.to_json %>"
  data-thread-workspace-focus-id-value="<%= @selected_weave_thread_id.to_i %>"
>
  <% if panel_threads.size >= 2 %>
    <% strip_focus_idx = panel_threads.index { |t| t.id == @selected_weave_thread_id.to_i } || 0 %>
    <div
      class="thread-strip-nav sticky left-0 z-10 flex w-full min-w-0 max-w-full shrink-0 justify-center bg-transparent pt-0.5 mb-5"
      data-thread-workspace-target="stripNav"
      aria-hidden="false"
    >
      <div
        id="workspace-thread-strip-carousel"
        class="relative inline-flex max-w-full flex-col items-center"
        data-thread-workspace-target="carouselRoot"
      >
        <%# Flowbite Carousel placeholder slides (programmatic init); visually hidden %>
        <div
          class="pointer-events-none absolute -left-[9999px] top-0 h-4 w-24 opacity-0"
          aria-hidden="true"
        >
          <div class="relative h-4 w-24">
            <% panel_threads.each_with_index do |_panel_thread, idx| %>
              <div
                id="workspace-thread-carousel-slide-<%= idx %>"
                data-carousel-item
                class="hidden"
              ></div>
            <% end %>
          </div>
        </div>
        <div
          class="flex flex-wrap items-center justify-center gap-3.5"
          role="tablist"
          aria-label="Open threads"
        >
          <% panel_threads.each_with_index do |panel_thread, idx| %>
            <span class="group relative inline-flex">
              <button
                type="button"
                id="workspace-thread-carousel-indicator-<%= idx %>"
                data-thread-strip-nav-indicator
                data-action="click->thread-workspace#stripNavIndicatorClick"
                data-thread-workspace-thread-id-param="<%= panel_thread.id %>"
                class="thread-strip-nav-indicator box-border inline-flex h-3 w-3 min-h-[1.25rem] min-w-[1.25rem] shrink-0 appearance-none items-center justify-center rounded-sm p-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500<%= idx == strip_focus_idx ? " thread-strip-nav--is-active" : " thread-strip-nav--is-inactive" %>"
                aria-label="<%= panel_thread.title.to_s.truncate(120) %>"
                title="<%= h(panel_thread.title.to_s) %>"
                aria-current="<%= (panel_thread.id == @selected_weave_thread_id.to_i) ? "true" : "false" %>"
              >
                <span class="sr-only"><%= panel_thread.title.to_s.truncate(120) %></span>
              </button>
              <span
                id="workspace-thread-nav-tooltip-<%= idx %>"
                role="tooltip"
                class="pointer-events-none absolute bottom-full left-1/2 z-50 mb-1.5 w-max max-w-[min(20rem,calc(100vw-2rem))] -translate-x-1/2 rounded-md bg-gray-900 px-2 py-1 text-left text-xs font-medium text-white opacity-0 shadow-lg transition-opacity duration-150 group-hover:opacity-100 group-focus-within:opacity-100 dark:bg-gray-700"
              >
                <%= panel_thread.title.to_s.presence || "Thread" %>
              </span>
            </span>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
  <div
    id="workspace-thread-workspace-strip"
    class="workspace-thread-workspace-strip flex h-full min-h-0 min-w-0 flex-1 flex-row overflow-x-auto overflow-y-hidden"
    data-thread-workspace-target="strip"
  >
    <% scope_h = workspace_thread_scope_params %>
    <% panel_threads.each do |panel_thread| %>
      <%= render "sequences/workspace_thread_panel_column",
                 panel_thread: panel_thread,
                 embed_query: embed_query,
                 editor_return_path: editor_return_path,
                 selected_weave_thread_id: @selected_weave_thread_id,
                 workspace_thread_scope_hash: scope_h %>
    <% end %>
  </div>
</div>
