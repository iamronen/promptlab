<%# Assistant (right column) — sequencing workspace layout. %>
<aside
  class="workspace-right-panel workspace-right-panel--assistant-only"
  aria-label="Assistant"
  data-workspace-assistant-toggle-target="assistant"
>
  <div class="workspace-right-panel-tabs-shell workspace-right-panel-tabs-shell--single">
    <div class="workspace-right-panel-panels">
      <div
        id="workspace-panel-assistant"
        class="workspace-right-panel-tabpanel workspace-right-panel-tabpanel--assistant workspace-right-panel-tabpanel--solo"
        role="tabpanel"
      >
        <div class="workspace-assistant-body">
          <p class="workspace-assistant-placeholder">
            Interactive LLM chat will appear here.
          </p>
        </div>
      </div>
    </div>
  </div>
</aside>
