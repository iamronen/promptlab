<% variant = local_assigns.fetch(:variant, :form_builder).to_sym %>
<% thread_panel_editor_embed = local_assigns.fetch(:thread_panel_editor_embed, false) %>
<% if variant == :form_builder %>
  <% f = local_assigns.fetch(:f) %>
  <section class="meta-fields prompt-thread-sequence-meta">
    <div class="sequence-heading-row<%= " sequence-heading-row--with-thread-body-toggle" if thread_panel_editor_embed %>">
      <% if thread_panel_editor_embed %>
        <button
          type="button"
          class="thread-editor-sequence-body-toggle prompt-thread-panel-icon-btn"
          data-thread-editor-body-collapse-target="toggle"
          data-action="click->thread-editor-body-collapse#toggle"
          aria-expanded="true"
          title="Show or hide step editors"
          aria-label="Show or hide step editors for this sequence"
        >
          <svg class="thread-editor-body-collapse-chevron" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
      <% end %>
      <div class="field field--sequence-title">
        <%= f.text_field :title,
                         required: true,
                         autocomplete: "off",
                         class: "sequence-title-input",
                         aria: { label: "Sequence title" },
                         data: {
                           sequence_editor_target: "titleInput",
                           action:
                             "focus->sequence-editor#selectAllIfDefault input->sequence-editor#markAutosaveDirtyFromInput blur->sequence-editor#restoreDefaultIfEmpty blur->sequence-editor#autosaveOnMetaBlur"
                         } %>
      </div>
    </div>
    <div class="field field--sequence-intent">
      <%= f.text_area :intent,
                       required: true,
                       rows: 1,
                       autocomplete: "off",
                       class: "sequence-intent-input",
                       aria: { label: "Intent" },
                       data: {
                         sequence_editor_target: "intentInput",
                         action:
                           "focus->sequence-editor#selectAllIfDefault input->sequence-editor#markAutosaveDirtyFromInput blur->sequence-editor#restoreDefaultIfEmpty blur->sequence-editor#autosaveOnMetaBlur"
                       } %>
    </div>
    <% taxonomy_subject = local_assigns.fetch(:taxonomy_subject, f.object) %>
    <% if taxonomy_subject.present? %>
      <%= render "sequences/sequence_meta_taxonomies_host",
                 project: @project,
                 sequence: taxonomy_subject,
                 subject_context: "standalone" %>
    <% end %>
  </section>
<% elsif variant == :bundle_child_tags %>
  <section class="meta-fields prompt-thread-sequence-meta">
    <div class="sequence-heading-row<%= " sequence-heading-row--with-thread-body-toggle" if thread_panel_editor_embed %>">
      <% if thread_panel_editor_embed %>
        <button
          type="button"
          class="thread-editor-sequence-body-toggle prompt-thread-panel-icon-btn"
          data-thread-editor-body-collapse-target="toggle"
          data-action="click->thread-editor-body-collapse#toggle"
          aria-expanded="true"
          title="Show or hide step editors"
          aria-label="Show or hide step editors for this sequence"
        >
          <svg class="thread-editor-body-collapse-chevron" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
      <% end %>
      <div class="field field--sequence-title">
        <%= text_field_tag local_assigns.fetch(:title_field_name),
                           local_assigns.fetch(:title_value),
                           required: true,
                           autocomplete: "off",
                           class: "sequence-title-input bundle-pipeline-child-title-input",
                           aria: { label: local_assigns.fetch(:title_label, "Generative sequence title") } %>
      </div>
    </div>
    <div class="field field--sequence-intent">
      <%= text_area_tag local_assigns.fetch(:intent_field_name),
                        local_assigns.fetch(:intent_value),
                        required: true,
                        rows: 1,
                        autocomplete: "off",
                        class: "sequence-intent-input bundle-pipeline-child-intent-input",
                        aria: { label: local_assigns.fetch(:intent_label, "Generative sequence intent") } %>
    </div>
    <% taxonomy_subject = local_assigns[:taxonomy_subject] %>
    <% if taxonomy_subject.present? %>
      <%= render "sequences/sequence_meta_taxonomies_host",
                 project: @project,
                 sequence: taxonomy_subject,
                 subject_context: "bundle_pipeline" %>
    <% end %>
  </section>
<% end %>
