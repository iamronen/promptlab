<% variant = local_assigns.fetch(:variant, :form_builder).to_sym %>
<% if variant == :form_builder %>
  <% f = local_assigns.fetch(:f) %>
  <section class="meta-fields">
    <div class="sequence-heading-row">
      <div class="field field--sequence-title">
        <%= f.text_field :title,
                         required: true,
                         autocomplete: "off",
                         class: "sequence-title-input",
                         aria: { label: "Sequence title" },
                         data: {
                           sequence_editor_target: "titleInput",
                           action:
                             "focus->sequence-editor#selectAllIfDefault input->sequence-editor#markAutosaveDirtyFromInput blur->sequence-editor#restoreDefaultIfEmpty blur->sequence-editor#autosaveOnMetaBlur"
                         } %>
      </div>
    </div>
    <div class="field field--sequence-intent">
      <%= f.text_area :intent,
                       required: true,
                       rows: 1,
                       autocomplete: "off",
                       class: "sequence-intent-input",
                       aria: { label: "Intent" },
                       data: {
                         sequence_editor_target: "intentInput",
                         action:
                           "focus->sequence-editor#selectAllIfDefault input->sequence-editor#markAutosaveDirtyFromInput blur->sequence-editor#restoreDefaultIfEmpty blur->sequence-editor#autosaveOnMetaBlur"
                       } %>
    </div>
  </section>
<% elsif variant == :bundle_child_tags %>
  <section class="meta-fields">
    <div class="sequence-heading-row">
      <div class="field field--sequence-title">
        <%= text_field_tag local_assigns.fetch(:title_field_name),
                           local_assigns.fetch(:title_value),
                           required: true,
                           autocomplete: "off",
                           class: "sequence-title-input bundle-pipeline-child-title-input",
                           aria: { label: local_assigns.fetch(:title_label, "Generative sequence title") } %>
      </div>
    </div>
    <div class="field field--sequence-intent">
      <%= text_area_tag local_assigns.fetch(:intent_field_name),
                        local_assigns.fetch(:intent_value),
                        required: true,
                        rows: 1,
                        autocomplete: "off",
                        class: "sequence-intent-input bundle-pipeline-child-intent-input",
                        aria: { label: local_assigns.fetch(:intent_label, "Generative sequence intent") } %>
    </div>
  </section>
<% end %>
