<%# locals: form_field_prefix, thread_panel_editor_embed, nested_step_card: (optional bool), placeholder: (optional bool), suppress_step_rail: (optional bool), step_row:, index: (ignored when placeholder) %>
<% placeholder = local_assigns.fetch(:placeholder, false) %>
<% nested_step_card = local_assigns.fetch(:nested_step_card, false) %>
<% thread_panel_editor_embed = local_assigns.fetch(:thread_panel_editor_embed, true) %>
<% suppress_step_rail = local_assigns.fetch(:suppress_step_rail, false) %>
<% suppress_move_to_thread = nested_step_card && thread_panel_editor_embed %>
<% sa = "#{form_field_prefix}[steps_attributes]" %>
<% step_card_classes = ["step-card"] %>
<% step_card_classes << "bundle-nested-step-card" if nested_step_card %>
<% step_card_classes << "step-card--thread-embed-steps" if thread_panel_editor_embed %>
<% step_card_classes << "prompt-thread-step-card" if thread_panel_editor_embed %>
<div class="step-row<%= " prompt-thread-step-row" if thread_panel_editor_embed %>" draggable="false" data-editor-kind="sequence_step" data-sequence-editor-target="stepCard">
  <% unless suppress_step_rail %>
    <%= render "sequences/thread_embed_sequence_step_rail",
               suppress_move_to_thread: suppress_move_to_thread %>
  <% end %>
  <article class="<%= step_card_classes.join(" ") %>">
    <span class="step-hidden-fields" aria-hidden="true">
      <% if placeholder %>
        <input type="hidden" name="<%= sa %>[NEW_RECORD][position]" value="0" data-sequence-editor-target="positionInput">
        <input type="hidden" name="<%= sa %>[NEW_RECORD][_destroy]" value="false" data-sequence-editor-target="destroyInput">
        <input type="hidden" name="<%= sa %>[NEW_RECORD][content]" value="" data-sequence-editor-target="contentInput">
      <% else %>
        <%= hidden_field_tag "#{sa}[#{index}][position]", step_row.position, id: false, data: { sequence_editor_target: "positionInput" } %>
        <%= hidden_field_tag "#{sa}[#{index}][_destroy]", "false", id: false, data: { sequence_editor_target: "destroyInput" } %>
        <%= hidden_field_tag "#{sa}[#{index}][content]", step_row.content, id: false, data: { sequence_editor_target: "contentInput" } %>
      <% end %>
    </span>
    <div class="step-number-area">
      <% step_label_text =
           if placeholder
             "Step"
           else
             step_row.position.to_s
           end %>
      <strong class="step-label" data-sequence-editor-target="stepLabel"><%= step_label_text %></strong>
    </div>

    <div class="step-content-area" data-action="click->sequence-editor#activateStep">
      <div
        class="rich-editor"
        contenteditable="false"
        data-sequence-editor-target="editor"
        data-action="input->sequence-editor#syncEditor keydown->sequence-editor#handleEditorKeydown paste->sequence-editor#handleEditorPaste"
      ><%= placeholder ? "".html_safe : step_row.content.to_s.html_safe %></div>
    </div>
  </article>
</div>
