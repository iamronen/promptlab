<% default_tab =
     if @sequence.transformation?
       "transformations"
     elsif @sequence.is_term?
       "terms"
     else
       "sequences"
     end %>
<aside class="workspace-sidebar" aria-label="Workspace sidebar">
  <div class="workspace-sidebar-back">
    <%= link_to "All projects", projects_path, class: "workspace-sidebar-back-link" %>
  </div>
  <div class="workspace-sidebar-header">
    <div class="workspace-sidebar-title-row">
      <h2 class="workspace-sidebar-title"><%= @project.name.to_s.truncate(36) %></h2>
      <div
        class="sequence-mode-toggle workspace-sidebar-mode-toggle"
        role="group"
        aria-label="Default mode when opening a sequence"
        data-controller="sequence-list-mode"
      >
        <button
          type="button"
          class="sequence-mode-btn"
          data-sequence-list-mode-target="modeReadonly"
          data-mode="readonly"
          data-action="sequence-list-mode#setMode"
          aria-pressed="true"
          title="Read-only"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        </button>
        <button
          type="button"
          class="sequence-mode-btn"
          data-sequence-list-mode-target="modeEdit"
          data-mode="edit"
          data-action="sequence-list-mode#setMode"
          aria-pressed="false"
          title="Edit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        </button>
      </div>
    </div>
  </div>
  <div
    class="workspace-sidebar-tabs-shell"
    data-controller="workspace-sidebar-tabs"
    data-workspace-sidebar-tabs-active-value="<%= default_tab %>"
  >
    <div class="workspace-sidebar-tablist-wrap">
      <div role="tablist" class="workspace-sidebar-tablist" aria-label="Sidebar lists">
        <button
          type="button"
          id="workspace-tab-transformations"
          role="tab"
          class="workspace-sidebar-tab"
          data-kind="transformations"
          data-workspace-sidebar-tabs-target="tab"
          data-action="workspace-sidebar-tabs#activate"
          aria-selected="<%= default_tab == "transformations" %>"
          aria-controls="workspace-panel-transformations"
          tabindex="<%= default_tab == "transformations" ? 0 : -1 %>"
        >
          Transformations
        </button>
        <button
          type="button"
          id="workspace-tab-sequences"
          role="tab"
          class="workspace-sidebar-tab"
          data-kind="sequences"
          data-workspace-sidebar-tabs-target="tab"
          data-action="workspace-sidebar-tabs#activate"
          aria-selected="<%= default_tab == "sequences" %>"
          aria-controls="workspace-panel-sequences"
          tabindex="<%= default_tab == "sequences" ? 0 : -1 %>"
        >
          Sequences
        </button>
        <button
          type="button"
          id="workspace-tab-terms"
          role="tab"
          class="workspace-sidebar-tab"
          data-kind="terms"
          data-workspace-sidebar-tabs-target="tab"
          data-action="workspace-sidebar-tabs#activate"
          aria-selected="<%= default_tab == "terms" %>"
          aria-controls="workspace-panel-terms"
          tabindex="<%= default_tab == "terms" ? 0 : -1 %>"
        >
          Terms
        </button>
      </div>
    </div>
    <div class="workspace-sidebar-panels">
      <div
        id="workspace-panel-transformations"
        class="workspace-sidebar-tabpanel"
        role="tabpanel"
        aria-labelledby="workspace-tab-transformations"
        data-kind="transformations"
        data-workspace-sidebar-tabs-target="panel"
        <%= "hidden" if default_tab != "transformations" %>
      >
        <div class="workspace-sidebar-tabpanel-toolbar">
          <%= button_to "New transformation",
                        project_transformations_path(@project),
                        method: :post,
                        form: { class: "sidebar-new-form" },
                        class: "secondary-button sidebar-new-button" %>
        </div>
        <%= render "sequences/sidebar_sequence_list",
                   items: @transformations,
                   current: @sequence,
                   project: @project,
                   list_kind: :transformations,
                   menu_actions_aria: "Transformation actions",
                   delete_confirm: "Delete this transformation? This cannot be undone." %>
      </div>
      <div
        id="workspace-panel-sequences"
        class="workspace-sidebar-tabpanel"
        role="tabpanel"
        aria-labelledby="workspace-tab-sequences"
        data-kind="sequences"
        data-workspace-sidebar-tabs-target="panel"
        <%= "hidden" if default_tab != "sequences" %>
      >
        <div class="workspace-sidebar-tabpanel-toolbar">
          <%= button_to "New sequence",
                        project_sequences_path(@project),
                        method: :post,
                        form: { class: "sidebar-new-form" },
                        class: "secondary-button sidebar-new-button" %>
        </div>
        <%= render "sequences/sidebar_sequence_list",
                   items: @sequences,
                   current: @sequence,
                   project: @project,
                   list_kind: :sequences,
                   menu_actions_aria: "Sequence actions",
                   delete_confirm: "Delete this sequence? This cannot be undone." %>
      </div>
      <div
        id="workspace-panel-terms"
        class="workspace-sidebar-tabpanel"
        role="tabpanel"
        aria-labelledby="workspace-tab-terms"
        data-kind="terms"
        data-workspace-sidebar-tabs-target="panel"
        <%= "hidden" if default_tab != "terms" %>
      >
        <div class="workspace-sidebar-tabpanel-toolbar">
          <%= button_to "New term",
                        project_sequences_path(@project),
                        method: :post,
                        params: { sequence: { is_term: true } },
                        form: { class: "sidebar-new-form" },
                        class: "secondary-button sidebar-new-button" %>
        </div>
        <%= render "sequences/sidebar_sequence_list",
                   items: @terms,
                   current: @sequence,
                   project: @project,
                   list_kind: :terms,
                   menu_actions_aria: "Term actions",
                   delete_confirm: "Delete this term? This cannot be undone." %>
      </div>
    </div>
  </div>
</aside>
