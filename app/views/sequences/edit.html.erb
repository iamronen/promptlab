<% content_for :title, "#{@sequence.title.presence || "Sequence"} · #{@project.name}" %>

<% project_heading = capture { render "sequences/project_tool_heading" } %>

<%= render layout: "shared/tool_container", locals: { variant: :full, heading_actions: project_heading } do %>
  <% if workspace_settings? %>
    <div
      class="workspace-settings-panel mx-auto box-border w-full max-w-[720px] overflow-y-auto px-5 py-8"
      data-controller="project-settings-modal"
    >
      <div class="tool-part">
        <div class="tool-part-body">
          <%= render "projects/project_settings_panel", return_to: workspace_settings_return_path %>
        </div>
      </div>
    </div>
  <% elsif workspace_process? %>
    <div class="workspace-shell workspace-shell--three-pane workspace-shell--process">
      <div class="workspace workspace--one-pane"
           data-workspace-font-size-target="scaleRoot">
        <%= render "process_workspace_main" %>
      </div>
    </div>
  <% else %>
    <div class="workspace-shell workspace-shell--three-pane workspace-shell--fabric">
      <div class="workspace workspace--one-pane"
           data-workspace-font-size-target="scaleRoot">
        <%= render "fabric_workspace_main" %>
      </div>
    </div>
  <% end %>
<% end %>
